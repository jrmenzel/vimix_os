{
    "env": {
        "kernel_inc_path": [
            "${workspaceFolder}/kernel/include",
            "${workspaceFolder}/kernel",
            "${workspaceFolder}/kernel/lib/libfdt",
            "${workspaceFolder}/mm",
            "${workspaceFolder}/usr/lib/libc",
            "${workspaceFolder}/usr/include",
            "${workspaceFolder}/build/kernel"
        ],
        "kernel_defines": [
            "DEBUG",
            "MEMORY_SIZE=64",
            "USER_TEXT_START=0x400000",
            "PHYS_OFFSET=0x80000000",
            "TEXT_OFFSET=0x200000"
        ],
        "kernel_defines_riscv": [
            "__ARCH_riscv",
            "CONFIG_RISCV_SBI",
            "__RISCV_EXT_SSTC",
            "__RISCV_CSR_TIME",
            "__BOOT_S_MODE"
        ],
        "user_inc_path": [
            "${workspaceFolder}/kernel/include",
            "${workspaceFolder}/usr/lib/libc",
            "${workspaceFolder}/usr/lib/libvimixutils",
            "${workspaceFolder}/usr/lib/tomlc17/src",
            "${workspaceFolder}/usr/include"
        ]
    },
    "configurations": [
        {
            "name": "64 bit RISCV Kernel Dev",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c17",
            "compilerPath": "/usr/bin/riscv64-linux-gnu-gcc",
            "includePath": [
                "${kernel_inc_path}",
                "${workspaceFolder}/kernel/arch/riscv"
            ],
            "defines": [
                "${kernel_defines}",
                "${kernel_defines_riscv}",
                "__riscv_xlen=64",
                "__ARCH_64BIT",
                "PAGE_OFFSET=0xFFFFFFC000000000"
            ],
            "compilerArgs": [
                "-nostdinc"
            ]
        },
        {
            "name": "32 bit RISCV Kernel Dev",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c17",
            "compilerPath": "/usr/bin/riscv64-linux-gnu-gcc",
            "includePath": [
                "${kernel_inc_path}",
                "${workspaceFolder}/kernel/arch/riscv"
            ],
            "defines": [
                "${kernel_defines}",
                "${kernel_defines_riscv}",
                "__riscv_xlen=32",
                "__ARCH_32BIT",
                "PAGE_OFFSET=0x80000000",
                "CONFIG_RISCV_BOOT_M_MODE"
            ],
            "compilerArgs": [
                "-nostdinc"
            ]
        },
        {
            "name": "64 bit RISCV userspace",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c17",
            "compilerPath": "/usr/bin/riscv64-linux-gnu-gcc",
            "includePath": [
                "${user_inc_path}"
            ],
            "defines": [
                "__riscv_xlen=64",
                "__ARCH_64BIT",
                "DEBUG"
            ],
            "compilerArgs": [
                "-nostdinc"
            ]
        },
        {
            "name": "userspace host",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c17",
            "compilerPath": "/usr/bin/gcc",
            "includePath": [
                "/usr/include",
                "/usr/lib/gcc/x86_64-pc-linux-gnu/13.2.1/include",
                "${workspaceFolder}/kernel/include",
                "${workspaceFolder}/usr/lib/libvimixutils",
                "${workspaceFolder}/usr/lib/tomlc17/src"
            ],
            "defines": [
                "MEMORY_SIZE=64",
                "BUILD_ON_HOST"
            ]
        }
    ],
    "version": 4
}