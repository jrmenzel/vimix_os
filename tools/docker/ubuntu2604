FROM ubuntu:26.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
    build-essential \
    apt-utils \
    gcc \
    make \
    git \
    clang \
    clang-format \
    gcc-riscv64-linux-gnu \
    qemu-system-riscv \
    gdb-multiarch \
    xxd \
    u-boot-tools \
    libelf-dev \
    libdw-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
