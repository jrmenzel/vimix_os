FROM ubuntu:24.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
    build-essential \
    apt-utils \
    gcc \
    make \
    git \
    clang \
    clang-format \
    gcc-riscv64-linux-gnu \
    qemu-system-riscv64 \
    gdb-multiarch \
    xxd \
    u-boot-tools \
    libelf-dev \
    libdw-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# additional spike requirements
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
    g++ \
    autoconf \
    automake \
    libtool \
    pkg-config \
    python3 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Build Spike (riscv-isa-sim) and put the `spike` binary on PATH
RUN git clone --recursive https://github.com/riscv-software-src/riscv-isa-sim.git /opt/riscv-isa-sim && \
    cd /opt/riscv-isa-sim && \
    mkdir -p build && cd build && \
    ../configure && \
    make -j $(nproc)

# Add the riscv-isa-sim build directory to PATH so `spike` is available
ENV PATH="/opt/riscv-isa-sim/build:${PATH}"
